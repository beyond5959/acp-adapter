{
  "name": "acp-adapter-npm-workspace",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "version:set": "node ./scripts/set-version.mjs",
    "build:binaries": "node ./scripts/build-binaries.mjs",
    "check:binaries": "node ./scripts/check-binaries.mjs",
    "pack:all": "npm run build:binaries && npm run check:binaries && node ./scripts/pack-all.mjs",
    "publish:all": "node ./scripts/publish-all.mjs"
  },
  "engines": {
    "node": ">=18"
  }
}
